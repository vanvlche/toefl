{
  "name": "toefl-vocab",
  "version": "1.0.0",
  "private": true,
  "description": "Offline TOEFL vocabulary PWA and Electron desktop wrapper.",
  "main": "desktop/electron/main.cjs",
  "scripts": {
    "desktop:dev": "electron .",
    "desktop:build": "electron-builder --win",
    "desktop:pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.toeflvocab.desktop",
    "productName": "TOEFL Vocab",
    "files": [
      "web/**/*",
      "desktop/electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
